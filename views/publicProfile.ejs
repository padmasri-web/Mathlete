<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Matiks - <%= user.name %> (@<%= user.username %>)</title>
  <meta name="description" content="View <%= user.name %>'s Matiks game ratings, streaks, achievements, stats overview, and recent duel history.">
  <!-- Bootstrap 5 CSS -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/dashboard.css">
  <link rel="stylesheet" href="/css/profile.css">
  <link rel="stylesheet" href="/css/backgroundFX.css">
</head>
<body>

  <div class="dashboard-container">
    <%- include('dashboard/leftbar') %>

    <main class="main-content">
      <%- include('dashboard/navbar') %>

      <div class="profile-grid-layout">
        <!-- Main Column (Left side) -->
        <div class="profile-main-column">
          
          <!-- User Details Card -->
          <div class="profile-card">
            <div class="profile-banner">
              <button class="banner-back-btn" onclick="window.location.href='/friends/find'" title="Back to Find Friends">←</button>
              
              <div class="banner-options-container" style="position: absolute; top: 15px; right: 15px; z-index: 10;">
                <button class="banner-options-btn">⋮</button>
              </div>

              <div class="banner-math-symbol" style="top: 15px; left: 20px; font-size: 20px;">%</div>
              <div class="banner-math-symbol" style="top: 25px; left: 100px; font-size: 22px;">+</div>
              <div class="banner-math-symbol" style="top: 80px; left: 25px; font-size: 24px;">×</div>
              <div class="banner-math-symbol" style="top: 15px; right: 120px; font-size: 20px;">−</div>
              <div class="banner-math-symbol" style="top: 70px; right: 30px; font-size: 22px;">÷</div>
              <div class="banner-math-symbol" style="top: 20px; right: 20px; font-size: 20px;">+</div>
              <span class="banner-rank-title">AMATEUR</span>
            </div>
            
            <div class="profile-avatar-large-wrapper">
              <div class="profile-avatar-large" id="profile-avatar-large" style="<%= user.avatarUrl ? 'background-image: url(' + user.avatarUrl + '); background-size: cover; background-position: center; color: transparent;' : '' %>">
                <%= user.avatarUrl ? '' : user.name.charAt(0) %>
              </div>
            </div>
            
            <div class="profile-info-body">
              <div>
                <h2 class="profile-main-name"><%= user.name %></h2>
                <div class="profile-main-username">@<%= user.username %></div>

                <!-- Head to Head Record -->
                <div style="margin: 10px 0 14px; font-size: 13px; font-weight: 700; color: #64748b;">
                  You vs 
                  <span style="color: #10b981;"><%= headToHead.wins %> Wins</span> / 
                  <span style="color: #f59e0b;"><%= headToHead.ties %> Ties</span> / 
                  <span style="color: #ef4444;"><%= headToHead.losses %> Loss</span>
                </div>

                <!-- Bio -->
                <% if (user.bio) { %>
                  <div class="profile-bio-text" style="color: #475569; font-size: 13px; margin-bottom: 12px; line-height: 1.4;">
                    <%= user.bio %>
                  </div>
                <% } %>

                <div class="profile-meta-pills" id="profile-meta-pills">
                  <div class="meta-pill-btn" style="border-color: #10b981; color: #10b981; cursor: default;">
                    <span style="font-weight: 800;">● <%= friendsCount %> Friends</span>
                  </div>

                  <% if (user.socials) { %>
                    <div class="social-badge-pill" onclick="window.open('<%= user.socials %>', '_blank')">
                      <span id="socials-btn-text"><%= user.socials.replace(/^(https?:\/\/)?(www\.)?/, '') %></span>
                    </div>
                  <% } %>
                </div>
              </div>
              
              <div class="profile-actions-row" style="margin-top: 20px;">
                <% if (friendStatus === 'pending_sent') { %>
                  <button class="action-green-btn" style="background: #f43f5e; border-color: #f43f5e; color: #ffffff;" onclick="toggleFriend('<%= user._id %>', this)">
                    WITHDRAW
                  </button>
                <% } else if (friendStatus === 'friends') { %>
                  <button class="action-green-btn" style="background: #3b82f6; border-color: #3b82f6; color: #ffffff;" onclick="toggleFriend('<%= user._id %>', this)">
                    FRIENDS ✓
                  </button>
                <% } else { %>
                  <button class="action-green-btn" onclick="toggleFriend('<%= user._id %>', this)">
                    + ADD FRIEND
                  </button>
                <% } %>

                <button class="action-green-btn" style="background: #10b981; border-color: #10b981; color: #ffffff; margin-left: 8px;" onclick="initiateChallenge('<%= user._id %>', '<%= user.username %>')">
                  CHALLENGE
                </button>

                <button class="action-icon-btn" onclick="copyProfileUrl()" style="margin-left: 8px;">
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
                </button>
              </div>
            </div>
          </div>

          <!-- Ratings Card -->
          <div class="profile-card">
            <div class="profile-card-header">
              <h3 class="profile-card-title">Ratings</h3>
              <button class="profile-card-arrow">→</button>
            </div>
            
            <div class="ratings-grid-row">
              <div class="rating-badge-item">
                <span class="rating-badge-square yellow"></span>
                <div class="rating-badge-val"><%= user.ratings ? user.ratings.math : 1000 %></div>
                <div class="rating-badge-label">MATH</div>
              </div>
              <div class="rating-badge-item">
                <span class="rating-badge-square pink"></span>
                <div class="rating-badge-val"><%= user.ratings ? user.ratings.logic : 1000 %></div>
                <div class="rating-badge-label">LOGIC</div>
              </div>
              <div class="rating-badge-item">
                <span class="rating-badge-square blue"></span>
                <div class="rating-badge-val"><%= user.ratings ? user.ratings.memory : 1000 %></div>
                <div class="rating-badge-label">MEMORY</div>
              </div>
              <div class="rating-badge-item">
                <span class="rating-badge-square cyan"></span>
                <div class="rating-badge-val"><%= user.ratings ? user.ratings.puzzle : 1000 %></div>
                <div class="rating-badge-label">PUZZLE</div>
              </div>
            </div>
          </div>

        </div>

        <!-- Side Column (Right side) -->
        <div class="profile-side-column">
          
          <!-- Rank Card -->
          <div class="profile-card">
            <div class="profile-card-header">
              <select class="rank-category-dropdown">
                <option value="math">⚙ Math Rank</option>
              </select>
              <button class="profile-card-arrow">→</button>
            </div>
            
            <div class="rank-display-container">
              <div class="rank-hexagon-icon">
                <svg viewBox="0 0 100 100" width="100" height="100">
                  <polygon points="50 3, 93 25, 93 75, 50 97, 7 75, 7 25" fill="#2b3b5c" stroke="#3b82f6" stroke-width="4"/>
                  <polygon points="50 15, 80 32, 80 68, 50 85, 20 68, 20 32" fill="#3b82f6"/>
                  <polygon points="50 30, 65 50, 50 70, 35 50" fill="#93c5fd"/>
                </svg>
              </div>
              <div class="rank-title-text">AMATEUR II</div>
            </div>
            
            <div class="rank-progress-wrapper">
              <div class="rank-progress-info">
                <span>RANK RATING</span>
                <span><%= user.ratings ? user.ratings.math : 1000 %>/1500</span>
              </div>
              <div class="rank-progress-bar-track">
                <div class="rank-progress-bar-fill" style="width: <%= ((user.ratings ? user.ratings.math : 1000) / 1500) * 100 %>%;"></div>
              </div>
            </div>
          </div>

          <!-- Stats Overview Card -->
          <div class="profile-card p-4">
            <h3 class="profile-card-title mb-3">Stats Overview</h3>
            
            <div class="stats-overview-grid">
              <div class="stat-box-item">
                <div class="stat-box-left">
                  <div class="stat-box-number"><%= user.streak || 1 %></div>
                  <div class="stat-box-label">MAX STREAK</div>
                </div>
                <div class="stat-box-icon yellow">🔥</div>
              </div>
              
              <div class="stat-box-item">
                <div class="stat-box-left">
                  <div class="stat-box-number"><%= user.xp || 0 %></div>
                  <div class="stat-box-label">TOTAL XP</div>
                </div>
                <div class="stat-box-icon cyan">⚡</div>
              </div>
              
              <div class="stat-box-item">
                <div class="stat-box-left">
                  <div class="stat-box-number">MATIKAN</div>
                  <div class="stat-box-label">LEAGUE</div>
                </div>
                <div class="stat-box-icon green">🛡️</div>
              </div>
              
              <div class="stat-box-item">
                <div class="stat-box-left">
                  <div class="stat-box-number">2</div>
                  <div class="stat-box-label">TOTAL GAMES</div>
                </div>
                <div class="stat-box-icon purple">🎮</div>
              </div>
            </div>
          </div>

        </div>

      </div>
    </main>
  </div>

  <script src="/socket.io/socket.io.js"></script>
  <script src="/js/socket/socketInit.js"></script>
  <script src="/js/socket/friendEvents.js"></script>
  <script>
    function copyProfileUrl() {
      const url = window.location.href;
      navigator.clipboard.writeText(url).then(() => {
        alert("Profile link copied to clipboard!");
      }).catch(() => {
        alert("Profile link: " + url);
      });
    }

    async function toggleFriend(targetUserId, btn) {
      try {
        const res = await fetch('/api/friends/request', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ targetUserId })
        });
        if (res.ok) {
          const data = await res.json();
          if (data.status === 'pending_sent') {
            btn.style.background = '#f43f5e';
            btn.style.borderColor = '#f43f5e';
            btn.style.color = '#ffffff';
            btn.textContent = 'WITHDRAW';

            if (window.socket) {
              window.socket.emit('send_friend_request', { targetUserId, senderName: '<%= currentUser.username %>' });
            }
          } else {
            btn.style.background = '#93f560';
            btn.style.borderColor = '#93f560';
            btn.style.color = '#1e293b';
            btn.textContent = '+ ADD FRIEND';
          }
        }
      } catch (err) {
        console.error("Error toggling friend:", err);
      }
    }

    function initiateChallenge(targetUserId, username) {
      if (window.socket) {
        window.socket.emit('invite_duel', { opponentId: targetUserId, gameMode: 'Sprint Duels' });
        alert(`Challenge invitation sent to @${username}!`);
      } else {
        alert(`Inviting @${username} to a live duel challenge...`);
      }
    }
  </script>
</body>
</html>
