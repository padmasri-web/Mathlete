<header class="top-header" id="dashboard-header">
  <!-- Online Friends List -->
  <div class="friends-section" id="active-friends-section">
    <div class="friends-list" id="active-friends-list">
      <!-- Active friends will load dynamically -->
    </div>
  </div>

  <!-- Wallet Stats -->
  <div class="wallet-stats" id="wallet-metrics">
    <div class="stat-pill coins" id="wallet-coins" title="Coins balance">
      <img src="/assets/svg/wallet.svg" alt="Coins">
      <span id="coins-count">--</span>
    </div>
    <div class="stat-pill drops" id="wallet-drops" title="Drops count">
      <span style="font-size: 14px;">🔥</span>
      <span id="drops-count">--</span>
    </div>
    <div class="stat-pill xp" id="wallet-xp" title="XP level">
      <span style="font-size: 14px;">⭐</span>
      <span id="xp-count">-- XP</span>
    </div>
  </div>
</header>
