  </div>

  <!-- User Profile Preview -->
  <div class="profile-preview" id="user-profile-preview" style="cursor: pointer;"
    onclick="window.location.href='/profile'">
    <div class="profile-avatar" id="user-avatar-initial"
      style="<%= (user && user.avatarUrl) ? 'background-image: url(' + user.avatarUrl + '); background-size: cover; background-position: center; color: transparent;' : '' %>">
      <%= (user && user.avatarUrl) ? '' : (user ? user.name.charAt(0) : 'J' ) %>
    </div>
    <div class="profile-details">
      <span class="profile-name" id="user-profile-name">
        <%= user ? user.name : 'Jhalak Yadav' %>
      </span>
      <span class="profile-username" id="user-profile-username">@<%= user ? user.username : 'jhalak_yadav' %></span>
    </div>
  </div>
</aside>

<!-- Coming Soon Modal -->
<div id="coming-soon-modal-backdrop"
  style="display: none; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(15, 23, 42, 0.6); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); z-index: 9999; align-items: center; justify-content: center; padding: 20px;">
  <div
    style="background: #ffffff; border: 2px solid #1e293b; border-radius: 24px; box-shadow: 0 12px 40px rgba(0, 0, 0, 0.25); width: 100%; max-width: 420px; padding: 28px 24px; text-align: center; position: relative;">
    <button onclick="closeComingSoonModal()"
      style="position: absolute; top: 16px; right: 18px; background: transparent; border: none; font-size: 22px; font-weight: 800; color: #64748b; cursor: pointer;">✕</button>

    <div id="cs-badge-icon"
      style="width: 64px; height: 64px; border-radius: 50%; background: #fef08a; border: 2px solid #1e293b; display: flex; align-items: center; justify-content: center; font-size: 32px; margin: 0 auto 16px; box-shadow: 0 4px 0 #1e293b;">
      🚀
    </div>

    <h2 id="cs-modal-title"
      style="font-family: var(--font-heading, 'Outfit', sans-serif); font-size: 22px; font-weight: 800; color: #1e293b; margin: 0 0 8px;">
      Coming Soon!
    </h2>

    <p id="cs-modal-desc"
      style="font-size: 14px; color: #64748b; font-weight: 500; line-height: 1.5; margin: 0 0 24px;">
      We're building something amazing! This feature will be available in the next update.
    </p>

    <button onclick="closeComingSoonModal()"
      style="width: 100%; background: #93f560; border: 2px solid #1e293b; color: #1e293b; padding: 12px 24px; border-radius: 14px; font-size: 15px; font-weight: 800; cursor: pointer; box-shadow: 0 4px 0 #1e293b; transition: all 0.15s ease;">
      Got it!
    </button>
  </div>
</div>

<script>
  function openComingSoonModal(event, featureName) {
    if (event) event.preventDefault();
    const modal = document.getElementById('coming-soon-modal-backdrop');
    const title = document.getElementById('cs-modal-title');
    const desc = document.getElementById('cs-modal-desc');
    const icon = document.getElementById('cs-badge-icon');

    if (featureName === 'Compete') {
      icon.innerHTML = '🏆';
      title.textContent = 'Compete Mode';
      desc.textContent = 'Ranked competitive tournaments, leaderboards, and head-to-head match-making are currently under active development. Coming very soon!';
    } else if (featureName === 'Group Play') {
      icon.innerHTML = '👥';
      title.textContent = 'Group Play';
      desc.textContent = 'Create custom multiplayer rooms, invite your friends, and play in custom battle lobbies together. Feature arriving in the next release!';
    } else if (featureName === 'Feed') {
      icon.innerHTML = '🔥';
      title.textContent = 'Matiks Feed';
      desc.textContent = 'Post your funny & fucked up game moments and share them directly with your friends and the community! Coming very soon.';
    } else {
      icon.innerHTML = '🚀';
      title.textContent = featureName + ' - Coming Soon!';
      desc.textContent = 'We are working hard to bring this feature to Matiks. Stay tuned!';
    }

    if (modal) modal.style.display = 'flex';
  }

  function closeComingSoonModal() {
    const modal = document.getElementById('coming-soon-modal-backdrop');
    if (modal) modal.style.display = 'none';
  }
</script>