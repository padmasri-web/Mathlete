  <!-- User Profile Preview -->
  <div class="profile-preview" id="user-profile-preview" style="cursor: pointer;" onclick="window.location.href='/profile'">
    <div class="profile-avatar" id="user-avatar-initial" style="<%= (user && user.avatarUrl) ? 'background-image: url(' + user.avatarUrl + '); background-size: cover; background-position: center; color: transparent;' : '' %>">
      <%= (user && user.avatarUrl) ? '' : (user ? user.name.charAt(0) : 'J') %>
    </div>
    <div class="profile-details">
      <span class="profile-name" id="user-profile-name"><%= user ? user.name : 'Jhalak Yadav' %></span>
      <span class="profile-username" id="user-profile-username">@<%= user ? user.username : 'jhalak_yadav' %></span>
    </div>
  </div>
