<div class="dashboard-right">
  
  <!-- Daily Quest Section -->
  <div class="quests-section" id="daily-quests-section">
    <div class="section-title-row">
      <h3 class="section-title"><span>📋</span> Daily Quest</h3>
      <a href="#" class="section-link" id="view-all-quests">View All</a>
    </div>
    
    <div class="quests-list" id="quests-render-list">
      <!-- Quests will render dynamically from server -->
    </div>
  </div>

  <!-- Download App Promotion Card -->
  <div class="card promo-card" id="download-promo-card">
    <div>
      <h3 class="promo-title">Download Mobile App</h3>
      <p class="promo-subtitle">Scan the QR code using your phone</p>
    </div>
    
    <div class="promo-content">
      <div class="qr-code-box" id="qr-code-wrapper">
        <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg" style="width: 100%; height: 100%;">
          <rect width="100" height="100" fill="white"/>
          <rect x="5" y="5" width="25" height="25" stroke="#52516E" stroke-width="4" fill="none"/>
          <rect x="10" y="10" width="15" height="15" fill="#52516E"/>
          <rect x="70" y="5" width="25" height="25" stroke="#52516E" stroke-width="4" fill="none"/>
          <rect x="75" y="10" width="15" height="15" fill="#52516E"/>
          <rect x="5" y="70" width="25" height="25" stroke="#52516E" stroke-width="4" fill="none"/>
          <rect x="10" y="75" width="15" height="15" fill="#52516E"/>
          <rect x="40" y="10" width="5" height="5" fill="#52516E"/>
          <rect x="50" y="15" width="10" height="5" fill="#52516E"/>
          <rect x="45" y="25" width="5" height="15" fill="#52516E"/>
          <rect x="70" y="40" width="15" height="5" fill="#52516E"/>
          <rect x="40" y="50" width="10" height="10" fill="#52516E"/>
          <rect x="80" y="50" width="5" height="10" fill="#52516E"/>
          <rect x="55" y="70" width="15" height="5" fill="#52516E"/>
          <rect x="75" y="70" width="10" height="10" fill="#52516E"/>
          <rect x="40" y="80" width="5" height="5" fill="#52516E"/>
          <rect x="50" y="85" width="15" height="5" fill="#52516E"/>
        </svg>
      </div>
      
      <div class="store-buttons" id="app-stores-wrapper">
        <a href="#" class="store-btn" id="store-apple">
          <span style="font-size: 16px;">🍏</span>
          <div class="store-btn-text">
            <span class="store-btn-tag">Download on the</span>
            <span class="store-btn-name">App Store</span>
          </div>
        </a>
        <a href="#" class="store-btn" id="store-google">
          <span style="font-size: 16px;">🤖</span>
          <div class="store-btn-text">
            <span class="store-btn-tag">Get it on</span>
            <span class="store-btn-name">Play Store</span>
          </div>
        </a>
      </div>
    </div>

    <div class="promo-illustration">🎮</div>
  </div>

</div>
