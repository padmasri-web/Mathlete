<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Matiks - Game History</title>
  <meta name="description" content="View your complete Matiks duel history, category filters, ratings, and stats.">
  <!-- Bootstrap 5 CSS -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/dashboard.css">
  <link rel="stylesheet" href="/css/profile.css">
  <link rel="stylesheet" href="/css/backgroundFX.css">
  <style>
    .history-card-list {
      display: flex;
      flex-direction: column;
      gap: 16px;
      margin-top: 20px;
      width: 100%;
    }
    .history-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      border-bottom: 1px solid var(--glass-border);
      padding-bottom: 15px;
      margin-bottom: 15px;
    }
    .back-profile-btn {
      padding: 8px 16px;
      border-radius: 10px;
      background: #111827;
      border: 2px solid #F58DB4; /* Soft Pink */
      color: #ffffff;
      font-size: 13px;
      font-weight: 700;
      transition: all 0.1s ease;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      box-shadow: 0px 3px 0px #F58DB4;
      cursor: pointer;
    }
    .back-profile-btn:hover {
      transform: translateY(1px);
      box-shadow: 0px 2px 0px #F58DB4;
    }
  </style>
</head>
<body>

  <div class="dashboard-container">
    <%- include('dashboard/leftbar') %>

    <main class="main-content">
      <%- include('dashboard/navbar') %>

      <div class="profile-section-card">
        <div class="history-header">
          <div class="d-flex align-items-center gap-3">
            <button class="back-profile-btn" onclick="window.location.href='/profile'">
              ← Back to Profile
            </button>
            <h2 class="section-header-title mb-0" style="font-size: 24px;">Match History Log</h2>
          </div>
          <span style="font-size: 12px; font-weight: 700; color: var(--text-primary); opacity: 0.7;">
            Total Matches: <%= gameLogs ? gameLogs.length : 0 %>
          </span>
        </div>

        <!-- Filter Tabs -->
        <div class="game-tabs-row" id="history-tabs-row" style="margin-bottom: 20px;">
          <button class="game-tab-item active d-inline-flex align-items-center gap-1" data-filter="All">
            🌌 All Games
          </button>
          <button class="game-tab-item d-inline-flex align-items-center gap-1" data-filter="Math">
            <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.45 1-1 1H4v2h16v-2h-5c-.55 0-1-.45-1-1v-2.34"/><path d="M12 2a7 7 0 0 0-7 7c0 2.5 2 4.5 4.5 5h5c2.5-.5 4.5-2.5 4.5-5a7 7 0 0 0-7-7z"/></svg>
            Math
          </button>
          <button class="game-tab-item d-inline-flex align-items-center gap-1" data-filter="Logic">
            <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="10" r="8"/><path d="M12 18v4"/><path d="M8 22h8"/></svg>
            Logic
          </button>
          <button class="game-tab-item d-inline-flex align-items-center gap-1" data-filter="Memory">
            <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96-.44 2.5 2.5 0 0 1 0-4.12 2.5 2.5 0 0 1 0-4.12A2.5 2.5 0 0 1 9.5 2z"/><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96-.44 2.5 2.5 0 0 0 0-4.12 2.5 2.5 0 0 0 0-4.12A2.5 2.5 0 0 0 14.5 2z"/></svg>
            Memory
          </button>
          <button class="game-tab-item d-inline-flex align-items-center gap-1" data-filter="Puzzle">
            <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v3"/><path d="M19 12h3"/><path d="M12 19v3"/><path d="M2 12h3"/><path d="M19 12a7 7 0 1 1-14 0 7 7 0 0 1 14 0z"/></svg>
            Puzzle
          </button>
        </div>

        <!-- History entries -->
        <div class="history-card-list" id="history-log-list-container">
          <% if (gameLogs && gameLogs.length > 0) { %>
            <% gameLogs.forEach(log => { %>
              <% 
                const logDate = log.playedAt ? new Date(log.playedAt).toLocaleDateString('en-US', { day: 'numeric', month: 'short' }) : '14th Jul';
                const logTime = log.playedAt ? new Date(log.playedAt).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) : '08:09 PM';
                const isWinner = log.playerScore >= log.opponentScore;
                const isOpponentWinner = log.opponentScore > log.playerScore;
                
                const modeTitle = log.challenge && log.challenge.title ? log.challenge.title : (log.mode || 'Sprint Duels');
                const categoryVal = log.challenge && log.challenge.category ? log.challenge.category : (log.category || 'Math');
              %>
              <div class="game-log-entry-card" data-category="<%= categoryVal %>">
                <div class="game-log-header-text">
                  <%= modeTitle %> • <%= logTime %> • <%= logDate %>
                </div>
                
                <div class="game-log-player-list">
                  <!-- Player 1 (You) -->
                  <div class="log-player-row">
                    <div class="log-player-left">
                      <div class="log-player-avatar active" style="background-color: var(--accent-royal-blue);"><%= user ? user.name.charAt(0) : 'J' %></div>
                      <div class="log-player-details">
                        <span class="log-player-username"><%= user ? user.username : 'jhalakyadav9779' %></span>
                        <span class="log-player-rank-rating">1003 <span class="rating-up">+<%= log.playerRatingChange %></span></span>
                      </div>
                    </div>
                    <div class="log-player-score-right">
                      <span class="log-player-score-val <%= isWinner ? 'winner' : '' %>"><%= log.playerScore %></span>
                      <% if (isWinner) { %>
                        <span style="color: #22c55e; font-size: 14px; font-weight: bold;">◀</span>
                      <% } %>
                    </div>
                  </div>
                  
                  <!-- Player 2 -->
                  <div class="log-player-row" style="opacity: 0.85;">
                    <div class="log-player-left">
                      <div class="log-player-avatar" style="background-color: var(--accent-hot-pink);"><%= log.opponentName ? log.opponentName.charAt(0).toUpperCase() : 'O' %></div>
                      <div class="log-player-details">
                        <span class="log-player-username"><%= log.opponentName || 'Opponent' %></span>
                        <span class="log-player-rank-rating">1005 <span class="rating-down"><%= log.opponentRatingChange >= 0 ? '+' : '' %><%= log.opponentRatingChange %></span></span>
                      </div>
                    </div>
                    <div class="log-player-score-right">
                      <span class="log-player-score-val <%= isOpponentWinner ? 'winner' : '' %>"><%= log.opponentScore %></span>
                      <% if (isOpponentWinner) { %>
                        <span style="color: #22c55e; font-size: 14px; font-weight: bold;">◀</span>
                      <% } %>
                    </div>
                  </div>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <div class="game-log-entry-card text-center" style="padding: 30px;">
              <span class="text-muted" style="font-size: 13px; font-weight: 600;">You haven't played any game matches yet!</span>
            </div>
          <% } %>
        </div>
      </div>
    </main>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const tabButtons = document.querySelectorAll('#history-tabs-row .game-tab-item');
      
      function filterHistory() {
        const activeTab = document.querySelector('#history-tabs-row .game-tab-item.active');
        if (!activeTab) return;
        
        const filter = activeTab.getAttribute('data-filter');
        const entries = document.querySelectorAll('#history-log-list-container .game-log-entry-card');
        
        let visibleCount = 0;
        entries.forEach(entry => {
          const category = entry.getAttribute('data-category');
          if (filter === 'All' || category === filter) {
            entry.style.display = 'flex';
            visibleCount++;
          } else {
            entry.style.display = 'none';
          }
        });
        
        const existingNoData = document.getElementById('no-history-message');
        if (existingNoData) existingNoData.remove();
        
        if (visibleCount === 0 && entries.length > 0) {
          const msgHtml = `
            <div class="game-log-entry-card text-center" id="no-history-message" style="padding: 30px;">
              <span class="text-muted" style="font-size: 13px; font-weight: 600;">No games played in this category yet.</span>
            </div>
          `;
          document.getElementById('history-log-list-container').insertAdjacentHTML('beforeend', msgHtml);
        }
      }

      tabButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          tabButtons.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          filterHistory();
        });
      });

      // Run initial filter on load
      filterHistory();
    });
  </script>
</body>
</html>
