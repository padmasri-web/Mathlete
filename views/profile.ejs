<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Matiks - User Profile</title>
  <meta name="description" content="View your Matiks game ratings, streaks, achievements, stats overview, and recent duel history.">
  <!-- Bootstrap 5 CSS -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/dashboard.css">
  <link rel="stylesheet" href="/css/profile.css">
  <link rel="stylesheet" href="/css/backgroundFX.css">
</head>
<body>

  <div class="dashboard-container">
    <%- include('dashboard/leftbar') %>

    <main class="main-content">
      <%- include('dashboard/navbar') %>

      <div class="profile-grid-layout">
        <!-- Main Column (Left side) -->
        <div class="profile-main-column">
          
          <!-- User Details Card -->
          <div class="profile-card">
            <div class="profile-banner">
              <button class="banner-back-btn" onclick="window.location.href='/'">←</button>
              <div class="banner-options-container" style="position: absolute; top: 15px; right: 15px; z-index: 10;">
                <button class="banner-options-btn" id="banner-options-btn" onclick="toggleSettingsDropdown(event)">⋮</button>
                <div class="settings-dropdown-menu" id="settings-dropdown-menu">
                  <button class="dropdown-item-btn" onclick="openEditProfileModal()">Update Profile</button>
                  <button class="dropdown-item-btn" onclick="alert('Privacy Settings: Standard high-security privacy protocol is active.')">Privacy</button>
                  <button class="dropdown-item-btn" onclick="alert('Support: Contact us at support@matiks.com')">Support</button>
                </div>
              </div>
              <div class="banner-math-symbol" style="top: 15px; left: 20px; font-size: 20px;">%</div>
              <div class="banner-math-symbol" style="top: 25px; left: 100px; font-size: 22px;">+</div>
              <div class="banner-math-symbol" style="top: 80px; left: 25px; font-size: 24px;">×</div>
              <div class="banner-math-symbol" style="top: 15px; right: 120px; font-size: 20px;">−</div>
              <div class="banner-math-symbol" style="top: 70px; right: 30px; font-size: 22px;">÷</div>
              <div class="banner-math-symbol" style="top: 20px; right: 20px; font-size: 20px;">+</div>
              <span class="banner-rank-title">NOVICE</span>
            </div>
            
            <div class="profile-avatar-large-wrapper">
              <div class="profile-avatar-large" id="profile-avatar-large" style="<%= (user && user.avatarUrl) ? 'background-image: url(' + user.avatarUrl + '); background-size: cover; background-position: center; color: transparent;' : '' %>">
                <%= (user && user.avatarUrl) ? '' : (user ? user.name.charAt(0) : 'J') %>
              </div>
            </div>
            
            <div class="profile-info-body">
              <div>
                <h2 class="profile-main-name" id="profile-main-name"><%= user.name %></h2>
                <div class="profile-main-username" id="profile-main-username">@<%= user.username %></div>
              </div>
              <div class="profile-friends-count d-flex align-items-center gap-1">
                <svg width="8" height="8" viewBox="0 0 10 10" style="margin-right: 2px;"><circle cx="5" cy="5" r="4" fill="#22c55e"/></svg>
                0 Friends
              </div>
              
              <div class="profile-meta-pills" id="profile-meta-pills">
                <button class="meta-pill-btn" id="college-btn" onclick="promptAddCollege()">
                  <span id="college-btn-icon"><%= user && user.collage ? '🎒' : '+' %></span> 
                  <span id="college-btn-text"><%= user && user.collage ? user.collage : 'Add College' %></span>
                </button>
                
                <% if (user && user.socials) { %>
                  <% 
                     let platform = 'generic';
                     let linkText = user.socials;
                     let lowerLink = user.socials.toLowerCase();
                     if (lowerLink.includes('linkedin')) platform = 'linkedin';
                     else if (lowerLink.includes('github')) platform = 'github';
                     else if (lowerLink.includes('twitter') || lowerLink.includes('x.com')) platform = 'twitter';
                     else if (lowerLink.includes('instagram')) platform = 'instagram';
                     
                     try {
                       let cleanUrl = user.socials.replace(/^(https?:\/\/)?(www\.)?/, '');
                       let parts = cleanUrl.split('/');
                       let namePart = parts.filter(p => p.trim() !== '').pop();
                       if (namePart) {
                         linkText = namePart;
                         if (linkText.length > 15) linkText = linkText.substring(0, 12) + '...';
                       }
                     } catch(e) {}
                  %>
                  <% if (platform === 'linkedin') { %>
                    <div class="social-badge-pill" id="socials-btn" onclick="window.open('<%= user.socials %>', '_blank')">
                      <div class="social-badge-icon-circle" style="background-color: #0077b5;">
                        <svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                      </div>
                      <span id="socials-btn-text"><%= linkText %></span>
                    </div>
                  <% } else if (platform === 'github') { %>
                    <div class="social-badge-pill" id="socials-btn" onclick="window.open('<%= user.socials %>', '_blank')">
                      <div class="social-badge-icon-circle" style="background-color: #24292e;">
                        <svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                      </div>
                      <span id="socials-btn-text"><%= linkText %></span>
                    </div>
                  <% } else if (platform === 'twitter') { %>
                    <div class="social-badge-pill" id="socials-btn" onclick="window.open('<%= user.socials %>', '_blank')">
                      <div class="social-badge-icon-circle" style="background-color: #000000;">
                        <svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                      </div>
                      <span id="socials-btn-text"><%= linkText %></span>
                    </div>
                  <% } else if (platform === 'instagram') { %>
                    <div class="social-badge-pill" id="socials-btn" onclick="window.open('<%= user.socials %>', '_blank')">
                      <div class="social-badge-icon-circle" style="background-color: #e1306c;">
                        <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
                      </div>
                      <span id="socials-btn-text"><%= linkText %></span>
                    </div>
                  <% } else { %>
                    <div class="social-badge-pill" id="socials-btn" onclick="window.open('<%= user.socials %>', '_blank')">
                      <div class="social-badge-icon-circle" style="background-color: #4b5563;">
                        <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                      </div>
                      <span id="socials-btn-text"><%= linkText %></span>
                    </div>
                  <% } %>
                <% } else { %>
                  <button class="meta-pill-btn" id="socials-btn" onclick="promptAddSocials()">
                    <span id="socials-btn-icon">+</span> <span id="socials-btn-text">Add Socials</span>
                  </button>
                <% } %>
              </div>
              
              <div class="profile-actions-row">
                <button class="action-green-btn" onclick="window.location.href='/friends/find'">
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 4px;"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
                  ADD MORE FRIENDS
                </button>
                <button class="action-icon-btn" onclick="copyProfileUrl()">
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
                </button>
              </div>
            </div>
          </div>

          <!-- Ratings Card -->
          <div class="profile-section-card">
            <div class="section-header-row">
              <h3 class="section-header-title">Ratings</h3>
              <button class="section-action-arrow">➔</button>
            </div>
            
            <div class="ratings-grid">
              <!-- Math Rating -->
              <div class="rating-item-box">
                <div class="rating-dot-badge" style="background: rgba(255, 210, 63, 0.12); color: #FFD23F;">
                  <svg width="10" height="10" viewBox="0 0 10 10" fill="currentColor"><rect width="10" height="10" rx="2" /></svg>
                </div>
                <span class="rating-number" id="rating-math-val"><%= (user && user.ratings) ? user.ratings.math : 1000 %></span>
                <span class="rating-label-name">Math</span>
              </div>
              
              <!-- Logic Rating -->
              <div class="rating-item-box">
                <div class="rating-dot-badge" style="background: rgba(244, 47, 118, 0.12); color: #F42F76;">
                  <svg width="10" height="10" viewBox="0 0 10 10" fill="currentColor"><rect width="10" height="10" rx="2" /></svg>
                </div>
                <span class="rating-number" id="rating-logic-val"><%= (user && user.ratings) ? user.ratings.logic : 1000 %></span>
                <span class="rating-label-name">Logic</span>
              </div>
              
              <!-- Memory Rating -->
              <div class="rating-item-box">
                <div class="rating-dot-badge" style="background: rgba(69, 100, 198, 0.12); color: #4564C6;">
                  <svg width="10" height="10" viewBox="0 0 10 10" fill="currentColor"><rect width="10" height="10" rx="2" /></svg>
                </div>
                <span class="rating-number" id="rating-memory-val"><%= (user && user.ratings) ? user.ratings.memory : 1000 %></span>
                <span class="rating-label-name">Memory</span>
              </div>
              
              <!-- Puzzle Rating -->
              <div class="rating-item-box">
                <div class="rating-dot-badge" style="background: rgba(80, 209, 224, 0.12); color: #50D1E0;">
                  <svg width="10" height="10" viewBox="0 0 10 10" fill="currentColor"><rect width="10" height="10" rx="2" /></svg>
                </div>
                <span class="rating-number" id="rating-puzzle-val"><%= (user && user.ratings) ? user.ratings.puzzle : 1000 %></span>
                <span class="rating-label-name">Puzzle</span>
              </div>
            </div>
          </div>

          <!-- Achievements Card -->
          <div class="profile-section-card">
            <div class="section-header-row">
              <h3 class="section-header-title">Achievements</h3>
              <button class="section-action-arrow">➔</button>
            </div>
            
            <div class="achievements-scroll-row">
              <!-- Streak 3 -->
              <div class="achievement-hexagon-wrapper">
                <svg viewBox="0 0 100 100" class="achievement-hexagon-bg">
                  <polygon points="50,5 95,25 95,75 50,95 5,75 5,25" fill="rgba(82, 81, 110, 0.08)" stroke="rgba(82, 81, 110, 0.15)" stroke-width="4"/>
                </svg>
                <div class="achievement-inner-content text-primary">
                  <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mb-1"><path d="M12 2c-.5 2.5-3 3.5-3 6.5A3 3 0 0 0 12 11.5a3 3 0 0 0 3-3c0-3-2.5-4-3-6.5z"/><path d="M9 16h6"/><path d="M10 20h4"/><path d="M12 11.5V16"/></svg>
                  <span class="achievement-hex-number">3</span>
                </div>
              </div>
              
              <!-- Streak 7 -->
              <div class="achievement-hexagon-wrapper">
                <svg viewBox="0 0 100 100" class="achievement-hexagon-bg">
                  <polygon points="50,5 95,25 95,75 50,95 5,75 5,25" fill="rgba(82, 81, 110, 0.08)" stroke="rgba(82, 81, 110, 0.15)" stroke-width="4"/>
                </svg>
                <div class="achievement-inner-content text-primary">
                  <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mb-1"><path d="M12 2c-.5 2.5-3 3.5-3 6.5A3 3 0 0 0 12 11.5a3 3 0 0 0 3-3c0-3-2.5-4-3-6.5z"/><path d="M9 16h6"/><path d="M10 20h4"/><path d="M12 11.5V16"/></svg>
                  <span class="achievement-hex-number">7</span>
                </div>
              </div>

              <!-- Streak 14 -->
              <div class="achievement-hexagon-wrapper">
                <svg viewBox="0 0 100 100" class="achievement-hexagon-bg">
                  <polygon points="50,5 95,25 95,75 50,95 5,75 5,25" fill="rgba(82, 81, 110, 0.08)" stroke="rgba(82, 81, 110, 0.15)" stroke-width="4"/>
                </svg>
                <div class="achievement-inner-content text-primary">
                  <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mb-1"><path d="M12 2c-.5 2.5-3 3.5-3 6.5A3 3 0 0 0 12 11.5a3 3 0 0 0 3-3c0-3-2.5-4-3-6.5z"/><path d="M9 16h6"/><path d="M10 20h4"/><path d="M12 11.5V16"/></svg>
                  <span class="achievement-hex-number">14</span>
                </div>
              </div>

              <!-- Streak 30 -->
              <div class="achievement-hexagon-wrapper">
                <svg viewBox="0 0 100 100" class="achievement-hexagon-bg">
                  <polygon points="50,5 95,25 95,75 50,95 5,75 5,25" fill="rgba(82, 81, 110, 0.08)" stroke="rgba(82, 81, 110, 0.15)" stroke-width="4"/>
                </svg>
                <div class="achievement-inner-content text-primary">
                  <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mb-1"><rect x="5" y="9" width="14" height="10" rx="2"/><path d="M8 9V5a4 4 0 0 1 8 0v4"/><line x1="9" y1="14" x2="15" y2="14"/><line x1="12" y1="9" x2="12" y2="19"/></svg>
                  <span class="achievement-hex-number">30</span>
                </div>
              </div>

              <!-- Streak 50 -->
              <div class="achievement-hexagon-wrapper" style="opacity: 0.5;">
                <svg viewBox="0 0 100 100" class="achievement-hexagon-bg">
                  <polygon points="50,5 95,25 95,75 50,95 5,75 5,25" fill="rgba(82, 81, 110, 0.04)" stroke="rgba(82, 81, 110, 0.1)" stroke-width="4"/>
                </svg>
                <div class="achievement-inner-content text-primary">
                  <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mb-1"><rect x="5" y="9" width="14" height="10" rx="2"/><path d="M8 9V5a4 4 0 0 1 8 0v4"/><line x1="9" y1="14" x2="15" y2="14"/><line x1="12" y1="9" x2="12" y2="19"/></svg>
                  <span class="achievement-hex-number">50</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Last 5 Games Card -->
          <div class="profile-section-card">
            <div class="section-header-row">
              <h3 class="section-header-title">Last 5 Games</h3>
              <button class="section-action-arrow" onclick="window.location.href='/profile/history'">➔</button>
            </div>
            
            <div class="game-tabs-row">
              <button class="game-tab-item active d-inline-flex align-items-center gap-1">
                <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.45 1-1 1H4v2h16v-2h-5c-.55 0-1-.45-1-1v-2.34"/><path d="M12 2a7 7 0 0 0-7 7c0 2.5 2 4.5 4.5 5h5c2.5-.5 4.5-2.5 4.5-5a7 7 0 0 0-7-7z"/></svg>
                Math
              </button>
              <button class="game-tab-item d-inline-flex align-items-center gap-1">
                <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="10" r="8"/><path d="M12 18v4"/><path d="M8 22h8"/></svg>
                Logic
              </button>
              <button class="game-tab-item d-inline-flex align-items-center gap-1">
                <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96-.44 2.5 2.5 0 0 1 0-4.12 2.5 2.5 0 0 1 0-4.12A2.5 2.5 0 0 1 9.5 2z"/><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96-.44 2.5 2.5 0 0 0 0-4.12 2.5 2.5 0 0 0 0-4.12A2.5 2.5 0 0 0 14.5 2z"/></svg>
                Memory
              </button>
              <button class="game-tab-item d-inline-flex align-items-center gap-1">
                <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v3"/><path d="M19 12h3"/><path d="M12 19v3"/><path d="M2 12h3"/><path d="M19 12a7 7 0 1 1-14 0 7 7 0 0 1 14 0z"/></svg>
                Puzzle
              </button>
            </div>
            
            <div class="game-log-list-container" id="game-log-list-container">
              <% if (typeof gameLogs !== 'undefined' && gameLogs && gameLogs.length > 0) { %>
                <% gameLogs.forEach(log => { %>
                  <% 
                    const logDate = log.playedAt ? new Date(log.playedAt).toLocaleDateString('en-US', { day: 'numeric', month: 'short' }) : '14th Jul';
                    const logTime = log.playedAt ? new Date(log.playedAt).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) : '08:09 PM';
                    const isWinner = log.playerScore >= log.opponentScore;
                    const isOpponentWinner = log.opponentScore > log.playerScore;
                  %>
                  <div class="game-log-entry-card" data-category="<%= log.category %>">
                    <div class="game-log-header-text">
                      <%= log.mode %> • <%= logTime %> • <%= logDate %>
                    </div>
                    
                    <div class="game-log-player-list">
                      <!-- Player 1 (You) -->
                      <div class="log-player-row">
                        <div class="log-player-left">
                          <div class="log-player-avatar active" style="background-color: var(--accent-royal-blue);"><%= user ? user.name.charAt(0) : 'J' %></div>
                          <div class="log-player-details">
                            <span class="log-player-username"><%= user ? user.username : 'jhalakyadav9779' %></span>
                            <span class="log-player-rank-rating">1003 <span class="rating-up">+<%= log.playerRatingChange %></span></span>
                          </div>
                        </div>
                        <div class="log-player-score-right">
                          <span class="log-player-score-val <%= isWinner ? 'winner' : '' %>"><%= log.playerScore %></span>
                          <% if (isWinner) { %>
                            <span style="color: #22c55e; font-size: 14px; font-weight: bold;">◀</span>
                          <% } %>
                        </div>
                      </div>
                      
                      <!-- Player 2 -->
                      <div class="log-player-row" style="opacity: 0.85;">
                        <div class="log-player-left">
                          <div class="log-player-avatar" style="background-color: var(--accent-hot-pink);"><%= log.opponentName ? log.opponentName.charAt(0).toUpperCase() : 'O' %></div>
                          <div class="log-player-details">
                            <span class="log-player-username"><%= log.opponentName || 'Opponent' %></span>
                            <span class="log-player-rank-rating">1005 <span class="rating-down"><%= log.opponentRatingChange >= 0 ? '+' : '' %><%= log.opponentRatingChange %></span></span>
                          </div>
                        </div>
                        <div class="log-player-score-right">
                          <span class="log-player-score-val <%= isOpponentWinner ? 'winner' : '' %>"><%= log.opponentScore %></span>
                          <% if (isOpponentWinner) { %>
                            <span style="color: #22c55e; font-size: 14px; font-weight: bold;">◀</span>
                          <% } %>
                        </div>
                      </div>
                    </div>
                  </div>
                <% }) %>
              <% } else { %>
                <div class="game-log-entry-card text-center" style="padding: 24px;">
                  <span class="text-muted" style="font-size: 12px; font-weight: 600;">No games played in this category yet.</span>
                </div>
              <% } %>
            </div>
          </div>

        </div>

        <!-- Sidebar Column (Right side) -->
