    function renderGameLogsUI(logs, user) {
      const container = document.getElementById('game-log-list-container');
      if (!container) return;
      
      container.innerHTML = '';
      if (!logs || logs.length === 0) {
        container.innerHTML = `
          <div class="game-log-entry-card text-center" style="padding: 24px;">
            <span class="text-muted" style="font-size: 12px; font-weight: 600;">No games played in this category yet.</span>
          </div>
        `;
        return;
      }

      logs.forEach(log => {
        const date = log.playedAt ? new Date(log.playedAt).toLocaleDateString('en-US', { day: 'numeric', month: 'short' }) : '14th Jul';
        const time = log.playedAt ? new Date(log.playedAt).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) : '08:09 PM';
        
        const isWinner = log.playerScore >= log.opponentScore;
        const isOpponentWinner = log.opponentScore > log.playerScore;
        
        // Handle nested/populated challenge object
        const modeTitle = log.challenge && log.challenge.title ? log.challenge.title : (log.mode || 'Sprint Duels');
        const categoryVal = log.challenge && log.challenge.category ? log.challenge.category : (log.category || 'Math');
        
        const html = `
          <div class="game-log-entry-card" data-category="${categoryVal}">
            <div class="game-log-header-text">
              ${modeTitle} • ${time} • ${date}
            </div>
            
            <div class="game-log-player-list">
              <div class="log-player-row">
                <div class="log-player-left">
                  <div class="log-player-avatar active" style="background-color: var(--accent-royal-blue);">${user.name ? user.name.charAt(0) : 'J'}</div>
                  <div class="log-player-details">
                    <span class="log-player-username">${user.username}</span>
                    <span class="log-player-rank-rating">1003 <span class="rating-up">+${log.playerRatingChange}</span></span>
                  </div>
                </div>
                <div class="log-player-score-right">
                  <span class="log-player-score-val ${isWinner ? 'winner' : ''}">${log.playerScore}</span>
                  ${isWinner ? '<span style="color: #22c55e; font-size: 14px; font-weight: bold;">◀</span>' : ''}
                </div>
              </div>
              
              <div class="log-player-row" style="opacity: 0.85;">
                <div class="log-player-left">
                  <div class="log-player-avatar" style="background-color: var(--accent-hot-pink);">${log.opponentName ? log.opponentName.charAt(0).toUpperCase() : 'O'}</div>
                  <div class="log-player-details">
                    <span class="log-player-username">${log.opponentName || 'Opponent'}</span>
                    <span class="log-player-rank-rating">1005 <span class="rating-down">${log.opponentRatingChange >= 0 ? '+' : ''}${log.opponentRatingChange}</span></span>
                  </div>
                </div>
                <div class="log-player-score-right">
                  <span class="log-player-score-val ${isOpponentWinner ? 'winner' : ''}">${log.opponentScore}</span>
                  ${isOpponentWinner ? '<span style="color: #22c55e; font-size: 14px; font-weight: bold;">◀</span>' : ''}
                </div>
              </div>
            </div>
          </div>
        `;
        container.insertAdjacentHTML('beforeend', html);
      });
      
      // Filter current active tab after rendering
      filterLogsByActiveTab();
    }

    function filterLogsByActiveTab() {
      const activeTab = document.querySelector('#game-tabs-row .game-tab-item.active');
      if (!activeTab) return;
      
      const filter = activeTab.getAttribute('data-filter');
      const entries = document.querySelectorAll('#game-log-list-container .game-log-entry-card');
      
      let visibleCount = 0;
      entries.forEach(entry => {
        const category = entry.getAttribute('data-category');
        if (category === filter) {
          entry.style.display = 'flex';
          visibleCount++;
        } else {
          entry.style.display = 'none';
        }
      });
      
      const existingNoData = document.getElementById('no-game-logs-message');
      if (existingNoData) existingNoData.remove();
      
      if (visibleCount === 0 && entries.length > 0) {
        const msgHtml = `
          <div class="game-log-entry-card text-center" id="no-game-logs-message" style="padding: 24px;">
            <span class="text-muted" style="font-size: 12px; font-weight: 600;">No games played in this category yet.</span>
          </div>
        `;
        document.getElementById('game-log-list-container').insertAdjacentHTML('beforeend', msgHtml);
      }
    }

    document.addEventListener('DOMContentLoaded', async () => {
      // Setup tabs filtering event listeners
      const tabButtons = document.querySelectorAll('#game-tabs-row .game-tab-item');
      tabButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          tabButtons.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          filterLogsByActiveTab();
        });
      });

      try {
        const res = await fetch('/api/user/profile');
        if (res.ok) {
          const user = await res.json();
          
          // Update profile fields
          const avatarInitial = user.name ? user.name.charAt(0) : 'J';
          const profileAvatarLarge = document.getElementById('profile-avatar-large');
          if (profileAvatarLarge) profileAvatarLarge.textContent = avatarInitial;
          const profileMainName = document.getElementById('profile-main-name');
          if (profileMainName) profileMainName.textContent = user.name;
          const profileMainUsername = document.getElementById('profile-main-username');
          if (profileMainUsername) profileMainUsername.textContent = `@${user.username}`;
          
          // Update College & Socials UI
          updateCollegeUI(user.collage);
          updateSocialsUI(user.socials);
          
          // Render game logs history
          if (user.gameLogs && user.gameLogs.length > 0) {
            renderGameLogsUI(user.gameLogs, user);
          } else {
            filterLogsByActiveTab();
          }
          
          // Update stats values
          const statTotalXp = document.getElementById('stat-total-xp');
          if (statTotalXp) statTotalXp.textContent = user.xp;
          
          // Math rank rating alignment
          const mathRating = user.ratings ? user.ratings.math : 1000;
          const rankRatingFractionText = document.getElementById('rank-rating-fraction-text');
          if (rankRatingFractionText) rankRatingFractionText.textContent = `${mathRating}/1200`;

          // Update ratings numbers on profile card
          if (user.ratings) {
            const mathVal = document.getElementById('rating-math-val');
            if (mathVal) mathVal.textContent = user.ratings.math;
            const logicVal = document.getElementById('rating-logic-val');
            if (logicVal) logicVal.textContent = user.ratings.logic;
            const memoryVal = document.getElementById('rating-memory-val');
            if (memoryVal) memoryVal.textContent = user.ratings.memory;
            const puzzleVal = document.getElementById('rating-puzzle-val');
            if (puzzleVal) puzzleVal.textContent = user.ratings.puzzle;
            
            const fill = document.querySelector('.rank-rating-bar-fill');
            if (fill) fill.style.width = `${(user.ratings.math / 1200) * 100}%`;
          }
          
          // Update sidebar elements too if they are loaded later
          const sidebarName = document.getElementById('user-profile-name');
          const sidebarUsername = document.getElementById('user-profile-username');
          const sidebarAvatar = document.getElementById('user-avatar-initial');
          if (sidebarName) sidebarName.textContent = user.name;
          if (sidebarUsername) sidebarUsername.textContent = `@${user.username}`;
          if (sidebarAvatar) sidebarAvatar.textContent = avatarInitial;
        }
      } catch (err) {
        console.warn("Could not load dynamic profile stats:", err);
      }
    });

    // Toggle Settings Dropdown Menu
    function toggleSettingsDropdown(event) {
      event.stopPropagation();
