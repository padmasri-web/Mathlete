  <!-- Dynamic Profile loading script -->
  <script>
    async function promptAddCollege() {
      const currentCollegeText = document.getElementById('college-btn-text')?.textContent.trim();
      const defVal = (currentCollegeText === 'Add College') ? '' : currentCollegeText;
      const collegeName = prompt("Enter your College name:", defVal);
      if (collegeName === null) return;
      
      try {
        const res = await fetch('/api/user/stats', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ collage: collegeName })
        });
        if (res.ok) {
          const user = await res.json();
          updateCollegeUI(user.collage);
        }
      } catch (err) {
        console.error("Failed to update college:", err);
      }
    }

    async function promptAddSocials() {
      const link = prompt("Enter your socials profile link (e.g. LinkedIn, GitHub, Twitter):");
      if (link === null) return;
      
      try {
        const res = await fetch('/api/user/stats', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ socials: link })
        });
        if (res.ok) {
          const user = await res.json();
          updateSocialsUI(user.socials);
        }
      } catch (err) {
        console.error("Failed to update socials:", err);
      }
    }

    function updateCollegeUI(collage) {
      const iconSpan = document.getElementById('college-btn-icon');
      const textSpan = document.getElementById('college-btn-text');
      if (collage) {
        if (iconSpan) iconSpan.textContent = '🎒';
        if (textSpan) textSpan.textContent = collage;
      } else {
        if (iconSpan) iconSpan.textContent = '+';
        if (textSpan) textSpan.textContent = 'Add College';
      }
    }

    function updateSocialsUI(socials) {
      const pillsContainer = document.getElementById('profile-meta-pills');
      if (!pillsContainer) return;
      
      const existingSocial = document.getElementById('socials-btn');
      if (existingSocial) {
        existingSocial.remove();
      }
      
      if (socials) {
        let platform = 'generic';
        let linkText = socials;
        let lowerLink = socials.toLowerCase();
        if (lowerLink.includes('linkedin')) platform = 'linkedin';
        else if (lowerLink.includes('github')) platform = 'github';
        else if (lowerLink.includes('twitter') || lowerLink.includes('x.com')) platform = 'twitter';
        else if (lowerLink.includes('instagram')) platform = 'instagram';
        
        try {
          let cleanUrl = socials.replace(/^(https?:\/\/)?(www\.)?/, '');
          let parts = cleanUrl.split('/');
          let namePart = parts.filter(p => p.trim() !== '').pop();
          if (namePart) {
            linkText = namePart;
            if (linkText.length > 15) linkText = linkText.substring(0, 12) + '...';
          }
        } catch(e) {}
        
        let html = '';
        if (platform === 'linkedin') {
          html = `
            <div class="social-badge-pill" id="socials-btn" onclick="window.open('${socials}', '_blank')">
              <div class="social-badge-icon-circle" style="background-color: #0077b5;">
