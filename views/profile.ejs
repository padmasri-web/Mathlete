      menu.classList.toggle('active');
    }

    // Close Dropdown when clicking outside
    window.addEventListener('click', () => {
      const menu = document.getElementById('settings-dropdown-menu');
      if (menu) menu.classList.remove('active');
    });

    // Open Edit Profile Modal
    function openEditProfileModal() {
      document.getElementById('edit-profile-modal').classList.add('active');
    }

    // Close Edit Profile Modal
    function closeEditProfileModal() {
      document.getElementById('edit-profile-modal').classList.remove('active');
    }

    let uploadedAvatarBase64 = '';

    function setAvatarPreview(imageUrl) {
      uploadedAvatarBase64 = imageUrl;
      const charEl = document.getElementById('edit-avatar-char');
      if (charEl) {
        charEl.style.backgroundImage = `url("${imageUrl}")`;
        charEl.style.backgroundSize = 'cover';
        charEl.style.backgroundPosition = 'center';
        charEl.style.color = 'transparent';
        charEl.textContent = '';
      }
    }

    function handleAvatarFileSelect(files) {
      if (files && files.length > 0) {
        const file = files[0];
        if (file && file.type.startsWith('image/')) {
          const reader = new FileReader();
          reader.onload = function(event) {
            const img = new Image();
            img.onload = function() {
              const canvas = document.createElement('canvas');
              const maxDim = 256;
              let width = img.width;
              let height = img.height;
              if (width > height) {
                if (width > maxDim) {
                  height *= maxDim / width;
                  width = maxDim;
                }
              } else {
                if (height > maxDim) {
                  width *= maxDim / height;
                  height = maxDim;
                }
              }
              canvas.width = width;
              canvas.height = height;
              const ctx = canvas.getContext('2d');
              ctx.drawImage(img, 0, 0, width, height);
              const compressedDataUrl = canvas.toDataURL('image/jpeg', 0.85);
              setAvatarPreview(compressedDataUrl);
            };
            img.src = event.target.result;
          };
          reader.readAsDataURL(file);
        }
      }
    }

    function copyProfileUrl() {
      const url = window.location.href;
      navigator.clipboard.writeText(url).then(() => {
        alert("Profile link copied to clipboard!");
      }).catch(err => {
        console.warn("Could not copy profile link via clipboard API, fallback copy running:", err);
        const tempInput = document.createElement("input");
        tempInput.value = url;
        document.body.appendChild(tempInput);
        tempInput.select();
        document.execCommand("copy");
        document.body.removeChild(tempInput);
        alert("Profile link copied to clipboard!");
      });
    }

    // Save Profile Changes
    async function handleProfileSave(event) {
      event.preventDefault();
      const name = document.getElementById('edit-name-val').value.trim();
      const username = document.getElementById('edit-username-val').value.trim();
      const country = document.getElementById('edit-country-val').value;
      const bio = document.getElementById('edit-bio-val').value.trim();
      const socials = document.getElementById('edit-socials-val').value.trim();

      const payload = { name, username, country, bio, socials };
      if (uploadedAvatarBase64) {
        payload.avatarUrl = uploadedAvatarBase64;
      }

      try {
        const res = await fetch('/api/user/stats', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });

        if (res.ok) {
          const updatedUser = await res.json();
          // Reload profile elements dynamically
          document.getElementById('profile-main-name').textContent = updatedUser.name;
          document.getElementById('profile-main-username').textContent = `@${updatedUser.username}`;
          
          const profileAvatarLarge = document.getElementById('profile-avatar-large');
          const editAvatarChar = document.getElementById('edit-avatar-char');
          const sidebarAvatar = document.getElementById('user-avatar-initial');

          if (updatedUser.avatarUrl) {
            if (profileAvatarLarge) {
              profileAvatarLarge.style.backgroundImage = `url(${updatedUser.avatarUrl})`;
              profileAvatarLarge.style.backgroundSize = 'cover';
              profileAvatarLarge.style.backgroundPosition = 'center';
              profileAvatarLarge.style.color = 'transparent';
              profileAvatarLarge.textContent = '';
            }
            if (editAvatarChar) {
              editAvatarChar.style.backgroundImage = `url(${updatedUser.avatarUrl})`;
              editAvatarChar.style.backgroundSize = 'cover';
              editAvatarChar.style.backgroundPosition = 'center';
              editAvatarChar.style.color = 'transparent';
              editAvatarChar.textContent = '';
            }
            if (sidebarAvatar) {
              sidebarAvatar.style.backgroundImage = `url(${updatedUser.avatarUrl})`;
              sidebarAvatar.style.backgroundSize = 'cover';
              sidebarAvatar.style.backgroundPosition = 'center';
              sidebarAvatar.style.color = 'transparent';
              sidebarAvatar.textContent = '';
            }
          } else {
            const avatarInitial = updatedUser.name ? updatedUser.name.charAt(0) : 'J';
            if (profileAvatarLarge) {
              profileAvatarLarge.style.backgroundImage = '';
              profileAvatarLarge.style.color = '';
              profileAvatarLarge.textContent = avatarInitial;
            }
            if (editAvatarChar) {
              editAvatarChar.style.backgroundImage = '';
              editAvatarChar.style.color = '';
              editAvatarChar.textContent = avatarInitial;
            }
            if (sidebarAvatar) {
              sidebarAvatar.style.backgroundImage = '';
              sidebarAvatar.style.color = '';
              sidebarAvatar.textContent = avatarInitial;
            }
          }

          updateSocialsUI(updatedUser.socials);

          const sidebarName = document.getElementById('user-profile-name');
          const sidebarUsername = document.getElementById('user-profile-username');
          if (sidebarName) sidebarName.textContent = updatedUser.name;
          if (sidebarUsername) sidebarUsername.textContent = `@${updatedUser.username}`;

          closeEditProfileModal();
        } else {
          alert('Failed to update profile values. Please try again.');
        }
      } catch (err) {
        console.error('Error saving profile:', err);
        alert('An error occurred while saving.');
      }
    }

    // Drag & Drop event registration
    window.addEventListener('DOMContentLoaded', () => {
      // Prevent browser default behavior of opening dragged files/images in the window
      window.addEventListener('dragover', (e) => e.preventDefault(), false);
      window.addEventListener('drop', (e) => e.preventDefault(), false);

      const dropZone = document.getElementById('edit-avatar-drop-zone');
      if (dropZone) {
        dropZone.addEventListener('dragover', (e) => {
          e.preventDefault();
          e.stopPropagation();
          dropZone.classList.add('dragover');
        });

        dropZone.addEventListener('dragleave', (e) => {
          e.preventDefault();
          e.stopPropagation();
          dropZone.classList.remove('dragover');
        });

        dropZone.addEventListener('drop', (e) => {
          e.preventDefault();
          e.stopPropagation();
          dropZone.classList.remove('dragover');

          // 1. Check local files
          if (e.dataTransfer.files && e.dataTransfer.files.length > 0) {
            handleAvatarFileSelect(e.dataTransfer.files);
            return;
          }

          // 2. Check dragged web image URLs or Data URIs
          const imageUrl = e.dataTransfer.getData('text/uri-list') || 
                           e.dataTransfer.getData('URL') || 
                           e.dataTransfer.getData('text/plain');
                           
          if (imageUrl && (imageUrl.startsWith('http') || imageUrl.startsWith('data:image'))) {
            setAvatarPreview(imageUrl);
            return;
          }

          // 3. Check HTML snippet if dragged from img element
          const htmlData = e.dataTransfer.getData('text/html');
          if (htmlData) {
            const tempDiv = document.createElement('div');
            tempDiv.innerHTML = htmlData;
            const imgEl = tempDiv.querySelector('img');
            if (imgEl && imgEl.src) {
              setAvatarPreview(imgEl.src);
            }
          }
        });
      }
    });
  </script>

  <!-- Edit Profile Modal Overlay -->
  <div class="edit-profile-overlay" id="edit-profile-modal">
    <div class="edit-profile-box">
      <button class="edit-profile-close-btn" onclick="closeEditProfileModal()">×</button>
      <h2 class="edit-profile-title">Edit Profile</h2>
      
      <div class="edit-avatar-section" id="edit-avatar-drop-zone">
        <div class="edit-avatar-circle" id="edit-avatar-char" style="<%= (user && user.avatarUrl) ? 'background-image: url(' + user.avatarUrl + '); background-size: cover; background-position: center; color: transparent;' : '' %>">
          <%= (user && user.avatarUrl) ? '' : (user ? user.name.charAt(0) : 'J') %>
        </div>
        <div class="edit-avatar-pencil-badge" onclick="document.getElementById('avatar-file-input').click()">✏️</div>
        <input type="file" id="avatar-file-input" style="display: none;" accept="image/*" onchange="handleAvatarFileSelect(this.files)">
      </div>

      <form id="edit-profile-form" onsubmit="handleProfileSave(event)">
        <span class="form-section-title">USER INTRO</span>
        
        <div class="form-input-wrapper">
          <label class="form-input-label">User Name *</label>
          <input type="text" class="form-input-field" id="edit-username-val" value="<%= user ? user.username : '' %>" required>
        </div>

        <div class="form-input-wrapper">
          <label class="form-input-label">Full Name *</label>
          <input type="text" class="form-input-field" id="edit-name-val" value="<%= user ? user.name : '' %>" required>
        </div>

        <div class="form-input-wrapper">
          <label class="form-input-label">Country *</label>
          <select class="form-input-field select-field" id="edit-country-val">
            <option value="India" <%= (user && user.country === 'India') ? 'selected' : '' %>>India</option>
            <option value="United States" <%= (user && user.country === 'United States') ? 'selected' : '' %>>United States</option>
            <option value="United Kingdom" <%= (user && user.country === 'United Kingdom') ? 'selected' : '' %>>United Kingdom</option>
            <option value="Canada" <%= (user && user.country === 'Canada') ? 'selected' : '' %>>Canada</option>
            <option value="Australia" <%= (user && user.country === 'Australia') ? 'selected' : '' %>>Australia</option>
          </select>
        </div>

        <div class="form-input-wrapper">
          <label class="form-input-label">Your Bio</label>
          <textarea class="form-input-field textarea-field" id="edit-bio-val" placeholder="Enter Your Bio (Optional)"><%= (user && user.bio) ? user.bio : '' %></textarea>
        </div>

        <div class="form-input-wrapper">
          <label class="form-input-label">Socials Link</label>
          <input type="text" class="form-input-field" id="edit-socials-val" value="<%= user ? user.socials : '' %>" placeholder="e.g. https://github.com/username">
        </div>

        <div class="awards-section-header">
          <span class="form-section-title">AWARDS & ACHIEVEMENTS</span>
          <button type="button" class="add-award-btn" onclick="alert('Awards & Achievements are linked to competitive rankings!')">Add +</button>
        </div>

        <button type="submit" class="profile-save-submit-btn">
          Save
        </button>
      </form>
    </div>
  </div>

</body>
</html>
