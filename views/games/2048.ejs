<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Matiks - 2048 Puzzle</title>
  <!-- Bootstrap 5 CSS -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/dashboard.css">
  <link rel="stylesheet" href="/css/backgroundFX.css">
  <link rel="stylesheet" href="/css/2048.css">
  <style>
    .game-wrapper {
      position: relative;
      z-index: 5;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 14px;
      padding: 20px 24px;
      background: var(--card-bg, rgba(251, 252, 252, 0.45));
      border: var(--card-border, 1px solid rgba(251, 252, 252, 0.6));
      border-radius: 24px;
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      box-shadow: var(--glass-shadow);
      max-width: 520px;
      margin: 0 auto;
      text-align: center;
    }

    .music-toggle-btn {
      width: 32px;
      height: 32px;
      padding: 0;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      background: rgba(255, 255, 255, 0.4);
      border: 1px solid rgba(82, 81, 110, 0.2);
      color: #52516E;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .music-toggle-btn:hover {
      transform: scale(1.1);
      background: rgba(255, 255, 255, 0.7);
    }
  </style>
</head>

<body>

  <div class="dashboard-container">
    <%- include('../dashboard/leftbar') %>

    <main class="main-content">
      <%- include('../dashboard/navbar') %>

      <div class="container-fluid py-3">

        <!-- 2048 Main Game Wrapper -->
        <div class="game-wrapper">

          <!-- Header Controls Row (Clean non-overlapping flex layout) -->
          <div class="w-100 d-flex justify-content-between align-items-center mb-1">
            <div class="d-flex align-items-center gap-2">
              <a href="/" class="btn btn-sm btn-outline-secondary rounded-pill px-3 fw-bold">← Arena</a>
              <button class="music-toggle-btn" id="music-toggle-btn" title="Toggle Music">🎵</button>
            </div>

            <h1 class="fw-extrabold text-uppercase m-0" style="font-family: var(--font-heading); font-size: 24px; color: #52516E;">2048 Puzzle</h1>

            <button id="new-game-btn" class="btn btn-sm btn-primary rounded-pill px-3 fw-bold shadow-sm">↻ Reset</button>
          </div>

          <p class="text-secondary small mb-2" style="font-size: 13px;">Slide numbers to combine matching tiles &amp; reach <strong>2048</strong>!</p>

          <!-- Score Pills & 2-Min Timer Bar -->
          <div class="d-flex align-items-center justify-content-center gap-3 w-100 mb-2">
            <div class="score-pill-box text-center">
              <span class="score-label">SCORE</span>
              <span id="current-score" class="score-value">0</span>
            </div>

            <div class="timer-badge shadow-sm" id="timer-badge" title="2-Min Countdown">
              <span style="font-size: 15px;">⏱️</span>
              <span id="game-timer" class="fw-bold fs-6" style="color: #4564C6; font-family: var(--font-heading);">02:00</span>
            </div>

            <div class="score-pill-box text-center">
              <span class="score-label">BEST</span>
              <span id="high-score" class="score-value">0</span>
            </div>
          </div>

          <!-- 4x4 Grid Board Wrapper -->
          <div class="grid-board-wrapper" id="grid-board-wrapper">
            <div class="grid-board" id="grid-board">
              <div class="grid-cell"></div><div class="grid-cell"></div><div class="grid-cell"></div><div class="grid-cell"></div>
              <div class="grid-cell"></div><div class="grid-cell"></div><div class="grid-cell"></div><div class="grid-cell"></div>
              <div class="grid-cell"></div><div class="grid-cell"></div><div class="grid-cell"></div><div class="grid-cell"></div>
              <div class="grid-cell"></div><div class="grid-cell"></div><div class="grid-cell"></div><div class="grid-cell"></div>
            </div>

            <!-- Dynamic Tile Container -->
            <div class="tile-container" id="tile-container"></div>
          </div>

        </div>

      </div>

      <!-- Game Over / Victory Modal -->
      <div class="modal fade" id="gameOver2048Modal" tabindex="-1" aria-labelledby="gameOver2048ModalLabel" aria-hidden="true" data-bs-backdrop="false">
        <div class="modal-dialog modal-dialog-centered">
          <div class="modal-content text-center p-4 border-0" style="border-radius: 28px; background: #ffffff; box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);">
            <div class="modal-header border-0 pb-0 justify-content-end p-0">
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            
            <div class="modal-body py-2">
              <div id="modal-icon-badge" class="mx-auto mb-3 d-flex align-items-center justify-content-center" style="width: 72px; height: 72px; border-radius: 50%; background: rgba(239, 68, 68, 0.15); font-size: 36px;">
                💀
              </div>
              <h2 class="fw-extrabold mb-1" id="gameOver2048ModalLabel" style="font-family: var(--font-heading); color: #52516E; font-size: 26px;">Game Over!</h2>
              <p class="text-secondary small mb-4" id="modal-2048-subtitle">No more valid moves possible on the board!</p>

              <div class="d-flex justify-content-center gap-3 mb-4">
                <div class="px-4 py-3 rounded-4" style="background: rgba(69, 100, 198, 0.08); border: 1px solid rgba(69, 100, 198, 0.15); min-width: 130px;">
                  <span class="d-block text-uppercase fw-bold text-muted small mb-1" style="font-size: 11px;">Final Score</span>
                  <span id="modal-final-score" class="fw-extrabold fs-3" style="color: #4564C6;">0</span>
                </div>
                <div class="px-4 py-3 rounded-4" style="background: rgba(16, 185, 129, 0.08); border: 1px solid rgba(16, 185, 129, 0.15); min-width: 130px;">
                  <span class="d-block text-uppercase fw-bold text-muted small mb-1" style="font-size: 11px;">Best Score</span>
                  <span id="modal-high-score" class="fw-extrabold fs-3" style="color: #10b981;">0</span>
                </div>
              </div>

              <div class="d-flex justify-content-center gap-3">
                <button type="button" class="btn btn-light rounded-pill px-4 py-2 fw-bold border" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary rounded-pill px-4 py-2 fw-bold shadow-sm" id="modal-restart-btn" data-bs-dismiss="modal">Play Again ↻</button>
              </div>
            </div>
          </div>
        </div>
      </div>

    </main>
  </div>

  <!-- Scripts -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/2048.js"></script>
</body>
</html>
