<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Matiks - Logic Challenge</title>
  <!-- Bootstrap 5 CSS -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/dashboard.css">
  <link rel="stylesheet" href="/css/backgroundFX.css">
  <style>
    .game-wrapper {
      position: relative;
      z-index: 5;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 14px;
      padding: 18px 24px;
      background: var(--card-bg, rgba(251, 252, 252, 0.4));
      border: var(--card-border, 1px solid rgba(251, 252, 252, 0.6));
      border-radius: 20px;
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      box-shadow: var(--glass-shadow);
      max-width: 580px;
      margin: 0 auto;
      text-align: center;
    }
    .logic-box {
      background: rgba(32, 32, 48, 0.7);
      border-radius: 14px;
      padding: 18px 22px;
      border: 1px solid rgba(255, 255, 255, 0.12);
      width: 100%;
      text-align: left;
      color: #fff;
    }
    .options-list {
      display: flex;
      flex-direction: column;
      gap: 10px;
      width: 100%;
    }
    .option-btn {
      width: 100%;
      padding: 10px 16px;
      background: rgba(32, 32, 48, 0.5);
      border: 1px solid rgba(255, 255, 255, 0.15);
      border-radius: 12px;
      color: #fff;
      font-size: 15px;
      font-weight: 600;
      text-align: left;
      cursor: pointer;
      transition: all 0.2s;
    }
    .option-btn:hover {
      background: rgba(80, 209, 224, 0.15);
      border-color: #50D1E0;
    }
    .option-btn.selected {
      background: linear-gradient(135deg, var(--accent-royal-blue), #50D1E0);
      border-color: #50D1E0;
      font-weight: 800;
    }
    .game-actions {
      display: flex;
      gap: 12px;
      margin-top: 4px;
    }
    .game-btn {
      padding: 8px 22px;
      background: linear-gradient(135deg, var(--accent-royal-blue), #50D1E0);
      border: none;
      border-radius: 12px;
      color: #fff;
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: 14px;
      cursor: pointer;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .game-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(80, 209, 224, 0.3);
    }
  </style>
</head>
<body>

  <div class="dashboard-container">
    <%- include('../dashboard/leftbar') %>

    <main class="main-content" style="padding: 15px 30px;">
      <%- include('../dashboard/navbar') %>

      <div style="padding: 10px 24px;">
        <div class="game-wrapper">
          <div class="game-header">
            <h1 style="font-family: var(--font-heading); font-weight: 800; text-transform: uppercase; color: var(--text-primary); font-size: 22px; margin: 0;">Logic Games</h1>
            <p style="color: rgba(82, 81, 110, 0.75); font-size: 12px; margin-top: 2px;">Solve the logic riddle to earn premium XP rewards!</p>
          </div>

          <div class="logic-box shadow-sm">
            <h3 style="margin-bottom: 8px; color: #FFD23F; font-size: 16px; font-weight: 800;">💡 Riddle of the Day:</h3>
            <p style="line-height: 1.6; margin: 0; font-size: 14px;">If a circle is one, a line is two, and a triangle is three, what is the value of a square?</p>
          </div>

          <div class="options-list" id="riddle-options">
            <button class="option-btn" onclick="selectOption(this, 1)">A) Three (3)</button>
            <button class="option-btn" onclick="selectOption(this, 2)">B) Four (4)</button>
            <button class="option-btn" onclick="selectOption(this, 3)">C) Five (5)</button>
            <button class="option-btn" onclick="selectOption(this, 4)">D) Six (6)</button>
          </div>

          <div class="game-actions">
            <button class="game-btn" onclick="submitAnswer()">Submit</button>
            <button class="game-btn" style="background: rgba(82, 81, 110, 0.1); border: 1px solid rgba(82, 81, 110, 0.2); color: var(--text-primary);" onclick="window.location.href='/'">Back</button>
          </div>
        </div>
      </div>
    </main>
  </div>

  <script>
    let selectedIndex = null;
    function selectOption(btn, val) {
      document.querySelectorAll('.option-btn').forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');
      selectedIndex = val;
    }
    function submitAnswer() {
      if (selectedIndex === null) {
        alert('Please select an option!');
        return;
      }
      if (selectedIndex === 2) {
        alert('Correct! A square has 4 sides. +200 XP and +100 Coins!');
      } else {
        alert('Incorrect. Give it another try!');
      }
    }
  </script>
  <script src="/js/main.js"></script>
  <script src="/js/backgroundFX.js"></script>
</body>
</html>
