<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Matiks - Cross Math Duel</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/dashboard.css">
  <style>
    .game-wrapper {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 20px;
      padding: 30px;
      background: var(--card-bg);
      border: var(--card-border);
      border-radius: 20px;
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      box-shadow: var(--card-shadow);
      max-width: 500px;
      margin: 0 auto;
      text-align: center;
    }
    .math-grid {
      display: grid;
      grid-template-columns: repeat(5, 50px);
      grid-gap: 10px;
      justify-content: center;
      align-items: center;
      margin: 20px 0;
    }
    .grid-cell {
      width: 50px;
      height: 50px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(18, 18, 29, 0.6);
      border: 1px solid rgba(255, 255, 255, 0.1);
      color: #fff;
      font-size: 20px;
      font-family: var(--font-body);
      font-weight: 700;
      border-radius: 8px;
    }
    .grid-cell.operator, .grid-cell.equals {
      background: transparent;
      border: none;
      color: var(--accent-hot-pink);
    }
    .grid-cell input {
      width: 100%;
      height: 100%;
      background: transparent;
      border: none;
      color: var(--accent-aqua);
      font-size: 20px;
      font-family: var(--font-body);
      font-weight: 700;
      text-align: center;
      outline: none;
    }
    .game-actions {
      display: flex;
      gap: 15px;
    }
    .game-btn {
      padding: 10px 20px;
      background: linear-gradient(135deg, var(--accent-royal-blue), #50D1E0);
      border: none;
      border-radius: 10px;
      color: #fff;
      font-family: var(--font-heading);
      font-weight: 800;
      cursor: pointer;
      transition: transform 0.2s;
    }
    .game-btn:hover {
      transform: translateY(-2px);
    }
  </style>
</head>
<body>

  <div class="dashboard-container">
    <%- include('../dashboard/leftbar') %>

    <main class="main-content">
      <%- include('../dashboard/navbar') %>

      <div style="padding: 24px;">
        <div class="game-wrapper">
          <div class="game-header">
            <h1 style="font-family: var(--font-heading); font-weight: 800; text-transform: uppercase; color: #fff;">Cross Math Duel</h1>
            <p style="color: var(--text-dim); margin-top: 5px;">Fill in the missing numbers to make all equations correct!</p>
          </div>

          <!-- A simple 5x5 Cross Math Grid -->
          <div class="math-grid">
            <!-- Row 1: 5 + 3 = 8 -->
            <div class="grid-cell">5</div>
            <div class="grid-cell operator">+</div>
            <div class="grid-cell"><input type="text" placeholder="?" id="c1" style="color: #FFD23F;"></div>
            <div class="grid-cell equals">=</div>
            <div class="grid-cell">8</div>

            <!-- Row 2: operator row -->
            <div class="grid-cell operator">+</div>
            <div class="grid-cell operator"></div>
            <div class="grid-cell operator">-</div>
            <div class="grid-cell operator"></div>
            <div class="grid-cell operator"></div>

            <!-- Row 3: 2 * 4 = 8 -->
            <div class="grid-cell">2</div>
            <div class="grid-cell operator">*</div>
            <div class="grid-cell">4</div>
            <div class="grid-cell equals">=</div>
            <div class="grid-cell">8</div>

            <!-- Row 4: operator row -->
            <div class="grid-cell equals">=</div>
            <div class="grid-cell operator"></div>
            <div class="grid-cell equals">=</div>
            <div class="grid-cell operator"></div>
            <div class="grid-cell operator"></div>

            <!-- Row 5: 7 - 1 = 6 -->
            <div class="grid-cell">7</div>
            <div class="grid-cell operator">-</div>
            <div class="grid-cell"><input type="text" placeholder="?" id="c2" style="color: #FFD23F;"></div>
            <div class="grid-cell equals">=</div>
            <div class="grid-cell">6</div>
          </div>

          <div class="game-actions">
            <button class="game-btn" onclick="const c1=document.getElementById('c1').value; const c2=document.getElementById('c2').value; if(c1==='3' && c2==='1') { alert('Correct! You earned +120 Coins!'); } else { alert('Try again!'); }">Submit</button>
            <button class="game-btn" style="background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);" onclick="window.location.href='/'">Back</button>
          </div>
        </div>
      </div>
    </main>
  </div>

  <script src="/js/main.js"></script>
  <script src="/js/crossMath.js"></script>
</body>
</html>
