<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Matiks - Snake Game</title>
  <!-- Bootstrap 5 CSS -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/dashboard.css">
  <link rel="stylesheet" href="/css/backgroundFX.css">
  <style>
    .game-wrapper {
      position: relative;
      z-index: 5;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 10px;
      padding: 12px 18px;
      background: var(--card-bg, rgba(251, 252, 252, 0.4));
      border: var(--card-border, 1px solid rgba(251, 252, 252, 0.6));
      border-radius: 20px;
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      box-shadow: var(--glass-shadow);
      max-width: 440px;
      margin: 0 auto;
      text-align: center;
    }
    .game-header h1 {
      font-family: var(--font-heading);
      font-weight: 800;
      text-transform: uppercase;
      color: var(--text-primary, #52516E);
      font-size: 20px;
      margin: 0;
    }
    .game-header p {
      color: rgba(82, 81, 110, 0.7);
      font-size: 11px;
      margin-top: 2px;
      margin-bottom: 2px !important;
    }
    .score-badge {
      background: rgba(80, 209, 224, 0.12);
      color: #0ea5e9;
      padding: 4px 14px;
      border-radius: 50px;
      font-family: var(--font-heading);
      font-weight: 800;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      border: 1px solid rgba(80, 209, 224, 0.25);
    }
    #game-canvas {
      background: #111827; /* Tailwind Gray 900 */
      border-radius: 12px;
      box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.3), 0 8px 10px -6px rgba(0, 0, 0, 0.3);
      border: 2px solid rgba(255, 255, 255, 0.1);
      width: 100%;
      max-width: 320px; /* Reduced from 400px to ensure it fits without scrolling */
      aspect-ratio: 1 / 1;
      display: block;
    }
    .game-actions {
      display: flex;
      gap: 15px;
      margin-top: 5px;
    }
    .game-btn {
      padding: 8px 20px;
      background: linear-gradient(135deg, var(--accent-royal-blue), #50D1E0);
      border: none;
      border-radius: 12px;
      color: #fff;
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: 14px;
      cursor: pointer;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .game-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(80, 209, 224, 0.3);
    }
  </style>
</head>
<body>

  <div class="dashboard-container">
    <%- include('../dashboard/leftbar') %>

    <main class="main-content">
      <%- include('../dashboard/navbar') %>

      <div style="padding: 10px 24px;">
        <div class="game-wrapper">
          <div class="game-header">
            <h1>Snake Game</h1>
            <p class="mb-1">Control the snake with Arrow keys or WASD. Eat red food to grow!</p>
          </div>

          <!-- Score Display -->
          <div class="d-flex align-items-center justify-content-between gap-3 w-100 px-1" style="max-width: 320px;">
            <div class="score-badge shadow-sm" id="score-badge" title="Current Score">
              <span>🍎</span>
              <span id="score-text">Score: 0</span>
            </div>
            
            <div style="font-size: 11px; font-weight: 700; color: var(--text-primary);">
              High Score: <span id="high-score-text">0</span>
            </div>
          </div>

          <!-- Canvas -->
          <canvas id="game-canvas" width="400" height="400"></canvas>

          <!-- Controls -->
          <div class="game-actions">
            <button id="restart-btn" class="game-btn">Restart Game</button>
            <button class="game-btn" style="background: rgba(82, 81, 110, 0.1); border: 1px solid rgba(82, 81, 110, 0.2); color: var(--text-primary);" onclick="window.location.href='/'">Back</button>
          </div>
        </div>
      </div>
    </main>
  </div>

  <!-- Scripts -->
  <script src="/js/main.js"></script>
  <script src="/js/snakeGame.js"></script>
  <script src="/js/backgroundFX.js"></script>
</body>
</html>
